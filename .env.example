# ═══════════════════════════════════════════════════════════════
# 鸡生蛋 Eggo · 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ═══════════════════════════════════════════════════════════════

# ── MySQL ───────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=eggo_root_2024
DB_HOST=mysql
DB_PORT=3306
DB_USER=eggo
DB_PASS=eggo_pass_2024
DB_NAME=jishengdan

# ── Redis ───────────────────────────────────────────────────────
REDIS_PASSWORD=eggo_redis_2024

# ── AI (Gemini) ─────────────────────────────────────────────────
OPENAI_API_KEY=your_gemini_api_key_here
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-3.1-flash-lite

# ── 爬虫配置 ────────────────────────────────────────────────────
CRAWL_FUND_CODES=110011,161725,012414

# ── 国内 API 代理（Cloudflare Worker）────────────────────────────
# 部署 Worker 后填入，为空则直连（境内服务器可不填）
CF_PROXY_URL=
CF_PROXY_KEY=eggo-proxy-2026
